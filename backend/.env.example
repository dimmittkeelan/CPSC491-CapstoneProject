# Copy to backend/.env and fill with your real values.
SESSION_SECRET=replace_with_a_long_random_secret
DATABASE_URL=https://pcbuild-server.onrender.com
PORT=3001

# Comma-separated origins allowed to call backend with cookies.
FRONTEND_ORIGIN=https://pc-build-generator.vercel.app

# Deployment cookie/proxy options (safe defaults are automatic).
# SESSION_COOKIE_SAMESITE accepts: lax, strict, none
SESSION_COOKIE_SAMESITE=none
SESSION_COOKIE_SECURE=true
TRUST_PROXY=true
